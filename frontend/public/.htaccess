<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Disable directory indexing
    Options -Indexes

    # 1. Serve existing files and directories normally (images, css, js, txt, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. If the user navigates without .html, silently map it to .html
    # Example: thaheembrothers.com/about => serves about.html
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # 3. Strip trailing slashes to prevent Next.js client-side routing bugs
    # Example: thaheembrothers.com/about/ => thaheembrothers.com/about
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]
</IfModule>

# Cache static files for performance
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# Handle Next.js 404 page gracefully
ErrorDocument 404 /404.html
