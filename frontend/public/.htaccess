# Configure Apache mod_rewrite for Next.js static routing with trailing slash
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Disable Apache directory listing to prevent 403 Forbidden
  Options -Indexes

  # Redirect non-trailing slash to trailing slash (except for files)
  # This ensures URLs are normalized to have trailing slashes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # 1. If it's an exact file (.css, .png, etc.), serve it
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 2. Map root to index.html
  RewriteRule ^$ index.html [L]

  # 3. If directory has an index.html, serve that internally
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.*)/$ $1/index.html [L]

  # Fallback to 404
  ErrorDocument 404 /404.html
</IfModule>
    
    # Cache static files for performance
    <IfModule mod_expires.c>
      ExpiresActive On
      ExpiresDefault "access plus 1 month"
      ExpiresByType text/html "access plus 0 seconds"
      ExpiresByType application/json "access plus 0 seconds"
    </IfModule>
    
    # php -- BEGIN cPanel-generated handler, do not edit
    # Set the “ea-php82” package as the default “PHP” programming language.
    <IfModule mime_module>
      AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
    </IfModule>
    # php -- END cPanel-generated handler, do not edit